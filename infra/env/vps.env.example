# Exemplo de variáveis para deploy na VPS
# Copie para .env na raiz de infra/ na VPS e substitua todos os valores
# "change-me-*" por valores reais e seguros.
# NUNCA commite o arquivo .env real no Git.

# PostgreSQL
POSTGRES_DB=ilex
POSTGRES_USER=ilex
POSTGRES_PASSWORD=change-me-vps-secret
POSTGRES_PORT=5432

# API FastAPI
API_PORT=8000
ILEX_APP_NAME=Ilex API
ILEX_ENVIRONMENT=production
ILEX_DATABASE_URL=postgresql+psycopg2://ilex:change-me-vps-secret@db:5432/ilex
ILEX_JWT_SECRET=change-me-vps-secret-replace-with-strong-random-key
ILEX_JWT_ALGORITHM=HS256
ILEX_JWT_ACCESS_MINUTES=30
ILEX_JWT_REFRESH_MINUTES=1440
ILEX_DEBUG=false
ILEX_REDIS_URL=redis://redis:6379/0

# Frontend Next.js
# Deve ser a URL pública e acessível pelo navegador do usuário
WEB_PORT=3000
NEXT_PUBLIC_API_URL=/api/v1

# CORS — origens permitidas para acessar a API (separadas por vírgula)
ILEX_CORS_ALLOWED_ORIGINS=https://app.exemplo.com.br
