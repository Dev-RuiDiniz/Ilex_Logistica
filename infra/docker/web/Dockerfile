# Dockerfile do frontend Ilex Logística (Next.js 16)
# Build multi-stage para otimizar imagem final

FROM node:20-alpine AS builder

WORKDIR /app

# Argumento de build para variáveis públicas do Next.js
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Instala dependências primeiro para aproveitar cache de layers
COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci

# Copia o restante do código e faz o build
COPY apps/web/ ./
RUN npm run build

# ---

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Copia apenas o necessário para executar em produção
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/node_modules ./node_modules

EXPOSE 3000

CMD ["npm", "start"]
